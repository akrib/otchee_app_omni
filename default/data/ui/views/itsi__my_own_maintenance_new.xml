<form version="1.1" theme="light" hideEdit="true"
      script="omni/maintenance_mine_app.js">
  <label>ITSI : Mes Maintenances</label>

  <!--
    Vue unique pilotee par le JS (cf. maintenance_mine_app.js).
    Tout est construit dans #omni_maintenance_mine_app.

    Memes mecaniques que la recherche, mais les resultats sont restreints
    aux maintenances dont l'utilisateur courant est l'auteur (creator),
    resolu via /services/authentication/current-context.

    Config (surchargeable par l'URL : ?debug=1&rows=50) :
      data-debug   : 0/1 -> logs console + bouton Debug
      data-rows    : nb de cartes par page (defaut 30)

    NB : si votre vue "my own maintenance" existe deja sous un autre nom de
    fichier, renommez ce fichier en consequence (et adaptez le data-* / les ids
    de montage dans le JS si necessaire).
  -->
  <fieldset submitButton="false" autoRun="false"></fieldset>

  <row>
    <panel>
      <html>
        <!-- Point de montage unique : l'appli JS construit tout ici -->
        <div id="omni_maintenance_mine_app"></div>

        <!-- Config par defaut (surchargee par l'URL si presente) -->
        <div id="omni_mine_config"
             data-debug="0"
             data-rows="30"
             style="display:none"></div>
      </html>
    </panel>
  </row>
</form>
