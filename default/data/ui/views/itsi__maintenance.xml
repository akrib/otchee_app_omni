<form version="1.1" theme="light" hideEdit="true"
      script="omni/maintenance_app.js">
  <label>ITSI : Maintenance</label>

  <!--
    ============================================================
    VUE UNIQUE  -  remplace les 5 anciens dashboards :
        itsi__add_maintenance.xml
        itsi__add_custom_maintenance.xml
        itsi__modify_maintenance.xml
        itsi__modify_custom_maintenance.xml
        itsi__delete_maintenance.xml

    Le mode est pilote par l'URL :
        ?mode=add
        ?mode=add_custom
        ?mode=update&dt_id=XXXX
        ?mode=update_custom&dt_id=XXXX
        ?mode=delete&dt_id=XXXX

    Fallbacks (dans l'ordre) :
        token "mode" / token "DT_ID"  ->  attributs data-* du div #omni_config

    Toute l'UI (stepper, etapes, periodes, loader, modal) est
    construite par maintenance_app.js dans #omni_maintenance_app.
    ============================================================
  -->

  <fieldset submitButton="false" autoRun="false"></fieldset>

  <row>
    <panel>
      <html>
        <!-- Unique point de montage : l'appli JS construit tout ici -->
        <div id="omni_maintenance_app"></div>

        <!-- Config par defaut (surchargee par l'URL si presente) -->
        <div id="omni_config" data-mode="add" data-debug="0" style="display:none"></div>
      </html>
    </panel>
  </row>
</form>
